{
  "name": "mcp-image-gen",
  "version": "1.0.0",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "test": "echo \"Error: no test specified\" && exit 1",
    "build": "tsc",
    "start": "node dist/server.js",
    "dev:mcp": "node --loader ts-node/esm --experimental-specifier-resolution=node src/server.ts",
    "dev:api": "node --loader ts-node/esm --experimental-specifier-resolution=node src/httpServer.ts",
    "dev:web": "cd web && npm run dev",
    "dev": "concurrently \"npm run dev:mcp\" \"npm run dev:api\" \"npm run dev:web\""
  },
  "keywords": [],
