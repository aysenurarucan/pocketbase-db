  "description": "",
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@huggingface/inference": "^4.13.12",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "pocketbase": "^0.26.8",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  }
